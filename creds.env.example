# Скопируй в creds.env и заполни своими значениями из залогиненного ChatGPT.
# DevTools -> Network -> любой запрос к chatgpt.com -> Copy -> Copy as cURL.
# Оттуда вытащи:
#   TOKEN       — из заголовка `authorization: Bearer <ЭТО>`
#   ACCOUNT_ID  — из заголовка `chatgpt-account-id: <ЭТО>`
#   COOKIES     — вся строка после `-b '...'` (или `cookie:` заголовок)
# Токен/куки протухают за дни — обнови, если получишь 401.

TOKEN='eyJ...'
ACCOUNT_ID='47a4...'
COOKIES='__Secure-next-auth.session-token.0=...; cf_clearance=...; _puid=...'
