# Copy to creds.env and fill in your own values from a logged-in ChatGPT session.
# DevTools -> Network -> any request to chatgpt.com -> Copy -> Copy as cURL.
# Pull out:
#   TOKEN       — from the `authorization: Bearer <THIS>` header
#   ACCOUNT_ID  — from the `chatgpt-account-id: <THIS>` header
#   COOKIES     — the whole string after `-b '...'` (or the `cookie:` header)
# Token/cookies expire within days — refresh them if you get a 401.

TOKEN='eyJ...'
ACCOUNT_ID='your-account-id'
COOKIES='__Secure-next-auth.session-token.0=...; cf_clearance=...; _puid=...'
